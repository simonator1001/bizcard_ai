# Database Configuration
POSTGRES_DB=postgres
POSTGRES_HOST=supabase-db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-postgres-password
SERVICE_PASSWORD_POSTGRES=your-secure-postgres-password

# JWT Configuration
SERVICE_PASSWORD_JWT=your-secure-jwt-secret
JWT_EXPIRY=3600

# Service Keys
SERVICE_SUPABASEANON_KEY=your-anon-key
SERVICE_SUPABASESERVICE_KEY=your-service-role-key

# Auth Service Configuration
SERVICE_USER_ADMIN=admin
SERVICE_PASSWORD_ADMIN=your-secure-admin-password
SERVICE_USER_MINIO=minio
SERVICE_PASSWORD_MINIO=your-secure-minio-password
SERVICE_PASSWORD_LOGFLARE=your-secure-logflare-password
SERVICE_PASSWORD_SUPAVISORSECRET=your-secure-supervisor-secret
SERVICE_PASSWORD_VAULTENC=your-secure-vault-key

# Domain and Protocol Settings
PROTOCOL=https
PORT=443
HOST=supabase.simon-gpt.com
COOKIE_DOMAIN=simon-gpt.com

# OAuth Providers
GOOGLE_CLIENT_ID=859959789432-2kae8tn3c94k4np401hscau3k1kk2l29.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# URLs
SITE_URL=https://bizcard.simon-gpt.com
API_URL=https://supabase.simon-gpt.com
SERVICE_FQDN_SUPABASEKONG=https://supabase.simon-gpt.com
SERVICE_FQDN_SUPABASEKONG_8000=https://supabase.simon-gpt.com

# Security Settings
COOKIE_SECURE=true
FUNCTIONS_VERIFY_JWT=true

# Analytics and Monitoring
NEXT_ANALYTICS_BACKEND_PROVIDER=postgres
NEXT_PUBLIC_ENABLE_LOGS=true 